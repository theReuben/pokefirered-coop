{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pokefirered-coop",
  "version": "0.1.0",
  "identifier": "com.pokefirered-coop.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Pokémon FireRed Co-Op",
        "width": 800,
        "height": 620,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "rom/pokefirered.gba": "rom/pokefirered.gba"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
